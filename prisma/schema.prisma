generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  contacts  Contact[]
  users     User[]
  createdAt DateTime  @default(now())
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  fullName       String?
  role           String       @default("vendedor") // admin, vendedor
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
}

model Contact {
  id             String       @id @default(uuid())
  phoneNumber    String
  name           String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  messages       Message[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, phoneNumber])
}

model Message {
  id        String   @id @default(uuid())
  body      String?
  isFromMe  Boolean  @default(false)
  type      String   @default("text")
  contact   Contact  @relation(fields: [contactId], references: [id])
  contactId String
  createdAt DateTime @default(now())
}